{
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/weather/(?<city>[^/]+)",
      "dest": "/api/weather/[city].js?city=$city"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
